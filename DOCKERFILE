# --- BASE: Install dependencies ---
FROM node:22-alpine AS base
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .

# --- BUILDER: Build both frontend and backend ---
FROM base AS builder
RUN npm run build:client
RUN npm run build:server

# --- TARGET: server (Used by the 'api' service) ---
FROM node:22-alpine AS server
WORKDIR /app
COPY --from=builder /app/package*.json ./
RUN npm install --omit=dev
COPY --from=builder /app/dist ./dist
# If you have an .env, it's usually passed via compose, not copied
EXPOSE 3000
CMD ["node", "dist/server.js"]

# --- Stage 3: Final Production Image (Nginx + Node) ---
FROM nginx:stable-alpine AS static-site
COPY nginx.conf /etc/nginx/nginx.conf
COPY --from=builder /app/dist/client /usr/share/nginx/html

# (Optional) If you want the same container to run the API:
# It's usually better to keep them separate in docker-compose, 
# but you can copy the server build here if needed.
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]